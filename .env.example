# ============================================================
# Veritas RAG — Environment Configuration
# ============================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- LLM Provider (pick one, comment out the other) ---
LLM_PROVIDER=google                        # "google" or "openai"

# Google Gemini (free tier — default)
GOOGLE_API_KEY=your-gemini-api-key-here

# OpenAI (swap to this if you have credits)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key-here

# --- Model Selection ---
CRITIC_MODEL=gemini-2.0-flash              # Cheap model for critic/rewriter
GENERATOR_MODEL=gemini-2.0-flash           # Main generation model
# CRITIC_MODEL=gpt-4o-mini                 # OpenAI alternative
# GENERATOR_MODEL=gpt-4o                   # OpenAI alternative

# --- Embeddings (local, no API key needed) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Reranker (local, no API key needed) ---
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Verifier (local, no API key needed) ---
VERIFIER_MODEL=cross-encoder/nli-deberta-v3-small

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=veritas_rag

# --- Retrieval ---
RETRIEVAL_TOP_K=20                          # Hybrid search returns this many
RERANK_TOP_K=6                              # Reranker narrows to this many
BM25_WEIGHT=0.3                             # Weight for BM25 in RRF fusion
DENSE_WEIGHT=0.7                            # Weight for dense in RRF fusion

# --- Ingestion ---
OCR_FALLBACK_CHAR_THRESHOLD=50             # Pages with fewer chars trigger OCR
CHUNK_SIZE=512                              # Characters per chunk
CHUNK_OVERLAP=64                            # Overlap between chunks

# --- Orchestration ---
MAX_REWRITE_RETRIES=1                       # Bounded retries (PRD: max 1)
MAX_REGEN_RETRIES=1                         # Bounded regeneration retries

# --- Logging ---
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                             # json | console

# --- API Server (Day 3+) ---
API_HOST=0.0.0.0
API_PORT=8000
